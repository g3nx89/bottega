{
  "name": "bottega",
  "version": "0.16.0",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:check": "npm run build && node scripts/check-bundle-size.mjs",
    "start": "npm run build && npx electron dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "BOTTEGA_AGENT_TEST=1 npm run build && npx playwright test --project=e2e",
    "test:uat": "BOTTEGA_AGENT_TEST=1 npm run build && npx playwright test --project=uat",
    "test:agent": "BOTTEGA_AGENT_TEST=1 npm run build && npx playwright test --project=agent",
    "test:agent:smoke": "BOTTEGA_AGENT_TEST=1 npm run build && npx playwright test --project=agent --grep @smoke",
    "test:agent:imagegen": "BOTTEGA_AGENT_TEST=1 npm run build && npx playwright test --project=imagegen",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "lint:types": "eslint src/",
    "lint:arch": "which semgrep > /dev/null 2>&1 && semgrep --config .semgrep/ src/ || echo 'semgrep not installed — install via: pip3 install semgrep'",
    "lint:dead": "knip",
    "benchmark:extraction": "tsx scripts/benchmark-extraction.ts",
    "check": "npm run validate",
    "validate": "concurrently -g npm:typecheck npm:lint npm:lint:types && concurrently -g npm:test npm:lint:dead npm:audit:deps",
    "audit:deps": "npm audit --audit-level=critical",
    "package": "npm run build && npx electron-builder --mac",
    "prepare": "husky"
  },
  "overrides": {
    "protobufjs": ">=7.5.5"
  },
  "dependencies": {
    "@axiomhq/pino": "^1.6.0",
    "@google/genai": "^1.50.1",
    "@iconify/core": "^4.1.0",
    "@iconify/utils": "^3.1.1",
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "@sinclair/typebox": "^0.34.49",
    "archiver": "^7.0.1",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.28.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.1.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "knip": "^6.0.6",
    "lint-staged": "^16.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.0",
    "yaml": "^2.8.3"
  },
  "lint-staged": {
    "{src,tests}/**/*.ts": [
      "biome check --write"
    ]
  },
  "build": {
    "appId": "com.bottega.app",
    "productName": "Bottega",
    "publish": {
      "provider": "github",
      "owner": "g3nx89",
      "repo": "bottega"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "sign": false
    },
    "asarUnpack": [
      "node_modules/esbuild/**",
      "node_modules/@esbuild/**"
    ],
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      "figma-desktop-bridge/**/*"
    ]
  }
}
