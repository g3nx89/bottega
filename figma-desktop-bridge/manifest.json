{
  "name": "Bottega Bridge",
  "id": "bottega-bridge",
  "api": "1.0.0",
  "main": "code.js",
  "ui": "ui.html",
  "editorType": ["figma", "dev"],
  "capabilities": ["inspect"],
  "enablePrivatePluginApi": true,
  "permissions": ["teamlibrary"],
  "documentAccess": "dynamic-page",
  "networkAccess": {
    "allowedDomains": [
      "http://localhost",
      "http://localhost:9280",
      "ws://localhost",
      "ws://localhost:9280"
    ],
    "reasoning": "Connects to local Bottega server via WebSocket on port 9280.",
    "devAllowedDomains": [
      "http://localhost",
      "http://localhost:9280",
      "ws://localhost",
      "ws://localhost:9280"
    ]
  }
}
